# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง — ห้าม commit .env ขึ้น GitHub
# Postgres นี้ใช้แค่สำหรับ Airflow metadata เท่านั้น (ไม่ใช่ที่เก็บข้อมูลโปรเจกต์)
POSTGRES_USER=airflow_meta
POSTGRES_PASSWORD=change_me_to_something_strong
POSTGRES_DB=airflow_metadata

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me_to_something_strong

YOUTUBE_API_KEY=

# BigQuery — ที่เก็บข้อมูลโปรเจกต์จริง (bronze/silver/gold)
GCP_PROJECT_ID=your-gcp-project-id
# ต้องมีไฟล์ gcp-service-account.json ในโฟลเดอร์นี้ด้วย (ดู README วิธีสร้าง)
